            "anyOf": [
              {
                "$ref": "#/components/schemas/ProductResponse"
              },
              {
                "type": "null"
              }
            ]
          },
          "quantity": {
            "type": "integer",
            "title": "Quantity"
          },
          "unit_price": {
            "type": "number",
            "title": "Unit Price"
          },
          "line_total": {
            "type": "number",
            "title": "Line Total"
          }
        },
        "type": "object",
        "required": [
          "id",
          "order_id",
          "product_id",
          "quantity",
          "unit_price",
          "line_total"
        ],
        "title": "OrderItemResponse"
